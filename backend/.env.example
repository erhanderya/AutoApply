# Database
DATABASE_URL=postgresql+psycopg://autoapply:secret@postgres:5432/autoapply

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
SECRET_KEY=change-this-to-a-random-256-bit-string
ACCESS_TOKEN_EXPIRE_HOURS=336

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://autoapply.local
OPENROUTER_APP_TITLE=AutoApply
CV_REFINER_MODEL=meta-llama/llama-3.1-8b-instruct:free,openai/gpt-4o-mini
ANALYZER_MODEL=meta-llama/llama-3.1-8b-instruct:free
WRITER_MODEL=meta-llama/llama-3.1-8b-instruct:free
FIT_SCORE_THRESHOLD=75
ANALYZE_BATCH_SIZE=10

# Adzuna
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb
